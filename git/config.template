# Git configuration — generated by git/install.py, do not edit by hand.
#
# This is a complete, self-contained config: no [include] directives,
# no symlinks. Both ~/.config/git/config and ~/.config/git/config.claude
# are produced from this same template, with different substitutions for
# {{signingkey}} and {{gpg_ssh_program}}.

[gpg]
	format = ssh

[gpg "ssh"]
	program = {gpg_ssh_program}
	allowedSignersFile = ~/.config/git/allowed-signers

[user]
	name = {name}
	email = {email}
	signingkey = {signingkey}

[commit]
	gpgsign = true

[core]
	editor = {editor}
	autocrlf = input
	excludesFile = ~/.gitignore

[init]
	defaultBranch = main

[pull]
	rebase = false

[push]
	default = simple
	followTags = true
	autoSetupRemote = true

[color]
	ui = auto

[alias]
	st = status
	co = checkout
	br = branch
	ci = commit
	pu = push
	pl = pull
	ss = stash save
	lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit

[credential]
	helper =
	helper = manager

[credential "https://dev.azure.com"]
	useHttpPath = true

[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
