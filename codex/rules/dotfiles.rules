# Commands that may run outside the sandbox without prompting.
prefix_rule(pattern = ["git", ["status", "diff", "log", "show", "branch", "add", "commit", "rm"]], decision = "allow")
prefix_rule(pattern = ["git", "remote", "-v"], decision = "allow")
prefix_rule(pattern = ["git", "pull", "--rebase"], decision = "allow")

prefix_rule(pattern = ["gh", "issue", ["list", "view", "status"]], decision = "allow")
prefix_rule(pattern = ["gh", "pr", ["list", "view", "diff", "checks", "status"]], decision = "allow")
prefix_rule(pattern = ["gh", "run", ["list", "view", "watch"]], decision = "allow")
prefix_rule(pattern = ["gh", "workflow", ["list", "view"]], decision = "allow")
prefix_rule(pattern = ["gh", "release", ["list", "view"]], decision = "allow")
prefix_rule(pattern = ["gh", "repo", "view"], decision = "allow")
prefix_rule(pattern = ["gh", "search", ["issues", "prs", "repos", "commits"]], decision = "allow")
prefix_rule(pattern = ["gh", "auth", "status"], decision = "allow")

prefix_rule(pattern = [["ls", "wc", "which", "head", "find"]], decision = "allow")
prefix_rule(pattern = ["mise", ["--version", "doctor", "tasks"]], decision = "allow")
prefix_rule(pattern = ["uv", "run", "ruff", "check"], decision = "allow")
prefix_rule(pattern = ["uv", "run", "ruff", "format", "--check"], decision = "allow")
prefix_rule(pattern = ["uv", "run", ["basedpyright", "pytest"]], decision = "allow")
prefix_rule(pattern = ["pnpm", ["lint", "typecheck", "build", "test"]], decision = "allow")
prefix_rule(pattern = ["go", ["test", "vet", "build", "version", "env"]], decision = "allow")
prefix_rule(pattern = ["cargo", ["check", "test", "clippy", "build", "doc", "--version"]], decision = "allow")
prefix_rule(pattern = ["cargo", "fmt", "--check"], decision = "allow")
prefix_rule(pattern = ["npm", "view"], decision = "allow")
prefix_rule(pattern = ["python3", "-m", "py_compile"], decision = "allow")
prefix_rule(pattern = ["python3", "--version"], decision = "allow")
prefix_rule(pattern = [["node", "rustc", "gh"], "--version"], decision = "allow")

# Destructive git operations always remain blocked.
prefix_rule(pattern = ["git", "commit", ["--amend", "--no-verify"]], decision = "forbidden")
prefix_rule(pattern = ["git", "push", ["--force", "-f", "--delete", "-d", "--prune"]], decision = "forbidden")
prefix_rule(pattern = ["git", "reset", "--hard"], decision = "forbidden")
prefix_rule(pattern = ["git", "clean", "-f"], decision = "forbidden")
