model = "azure/gpt-5-6-sol"
model_provider = "sbpai"
model_catalog_json = "/Users/lsimons/.codex/models.json"
personality = "pragmatic"
model_reasoning_effort = "low"
approval_policy = "on-request"
sandbox_mode = "workspace-write"
web_search = "cached"

[sandbox_workspace_write]
network_access = true

[features]
multi_agent = true

[features.network_proxy]
enabled = true
domains = { "github.com" = "allow", "api.github.com" = "allow", "codeload.github.com" = "allow", "uploads.github.com" = "allow", "objects.githubusercontent.com" = "allow", "raw.githubusercontent.com" = "allow" }
dangerously_allow_all_unix_sockets = true

[analytics]
enabled = false

[feedback]
enabled = false

[model_providers.sbpai]
name = "SBP AI"
base_url = "https://litellm.sbp.ai"
env_key = "OPENAI_API_KEY"
# wire_api = "chat"

[projects."/Users/lsimons/sbp/conf2share"]
trust_level = "trusted"

[projects."/Users/lsimons/git/lsimons/lsimons-dotfiles"]
trust_level = "trusted"

[tui.model_availability_nux]
"azure/gpt-5-6-sol" = 4
"gpt-5.5" = 2
"gpt-5.6-sol" = 4
