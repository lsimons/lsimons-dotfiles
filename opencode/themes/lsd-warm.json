{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "darkWarm": "#d79e59",
    "darkInk": "#dfcab2",
    "darkMuted": "#8a7761",
    "darkFaint": "#5e4c38",
    "darkGreen": "#007a5e",
    "darkRed": "#c10032",
    "darkGold": "#eabb79",
    "darkBlue": "#005fc9",
    "darkMagenta": "#c8005e",
    "darkTeal": "#007980",
    "darkPanel": "#1f1000",
    "darkElement": "#261704",
    "lightWarm": "#c17a23",
    "lightInk": "#241100",
    "lightMuted": "#594329",
    "lightFaint": "#947b60",
    "lightGreen": "#006248",
    "lightRed": "#a10000",
    "lightGold": "#906d00",
    "lightBlue": "#0045ae",
    "lightMagenta": "#aa0048",
    "lightTeal": "#006168",
    "lightPanel": "#f7e9d6",
    "lightElement": "#fbecd9"
  },
  "theme": {
    "primary": { "dark": "darkWarm", "light": "lightWarm" },
    "secondary": { "dark": "darkTeal", "light": "lightTeal" },
    "accent": { "dark": "darkBlue", "light": "lightBlue" },
    "error": { "dark": "darkRed", "light": "lightRed" },
    "warning": { "dark": "darkGold", "light": "lightGold" },
    "success": { "dark": "darkGreen", "light": "lightGreen" },
    "info": { "dark": "darkBlue", "light": "lightBlue" },
    "text": { "dark": "darkInk", "light": "lightInk" },
    "textMuted": { "dark": "darkMuted", "light": "lightMuted" },
    "background": "none",
    "backgroundPanel": { "dark": "darkPanel", "light": "lightPanel" },
    "backgroundElement": { "dark": "darkElement", "light": "lightElement" },
    "border": { "dark": "darkFaint", "light": "lightFaint" },
    "borderActive": { "dark": "darkWarm", "light": "lightWarm" },
    "borderSubtle": { "dark": "darkFaint", "light": "lightFaint" },
    "diffAdded": { "dark": "darkGreen", "light": "lightGreen" },
    "diffRemoved": { "dark": "darkRed", "light": "lightRed" },
    "diffContext": { "dark": "darkMuted", "light": "lightMuted" },
    "diffHunkHeader": { "dark": "darkWarm", "light": "lightWarm" },
    "diffHighlightAdded": { "dark": "darkGreen", "light": "lightGreen" },
    "diffHighlightRemoved": { "dark": "darkRed", "light": "lightRed" },
    "diffAddedBg": { "dark": "darkElement", "light": "lightElement" },
    "diffRemovedBg": { "dark": "darkElement", "light": "lightElement" },
    "diffContextBg": { "dark": "darkPanel", "light": "lightPanel" },
    "diffLineNumber": { "dark": "darkFaint", "light": "lightFaint" },
    "diffAddedLineNumberBg": { "dark": "darkElement", "light": "lightElement" },
    "diffRemovedLineNumberBg": { "dark": "darkElement", "light": "lightElement" },
    "markdownText": { "dark": "darkInk", "light": "lightInk" },
    "markdownHeading": { "dark": "darkWarm", "light": "lightWarm" },
    "markdownLink": { "dark": "darkBlue", "light": "lightBlue" },
    "markdownLinkText": { "dark": "darkTeal", "light": "lightTeal" },
    "markdownCode": { "dark": "darkTeal", "light": "lightTeal" },
    "markdownBlockQuote": { "dark": "darkMuted", "light": "lightMuted" },
    "markdownEmph": { "dark": "darkGold", "light": "lightGold" },
    "markdownStrong": { "dark": "darkWarm", "light": "lightWarm" },
    "markdownHorizontalRule": { "dark": "darkFaint", "light": "lightFaint" },
    "markdownListItem": { "dark": "darkWarm", "light": "lightWarm" },
    "markdownListEnumeration": { "dark": "darkTeal", "light": "lightTeal" },
    "markdownImage": { "dark": "darkBlue", "light": "lightBlue" },
    "markdownImageText": { "dark": "darkTeal", "light": "lightTeal" },
    "markdownCodeBlock": { "dark": "darkInk", "light": "lightInk" },
    "syntaxComment": { "dark": "darkFaint", "light": "lightFaint" },
    "syntaxKeyword": { "dark": "darkWarm", "light": "lightWarm" },
    "syntaxFunction": { "dark": "darkBlue", "light": "lightBlue" },
    "syntaxVariable": { "dark": "darkGold", "light": "lightGold" },
    "syntaxString": { "dark": "darkGreen", "light": "lightGreen" },
    "syntaxNumber": { "dark": "darkMagenta", "light": "lightMagenta" },
    "syntaxType": { "dark": "darkTeal", "light": "lightTeal" },
    "syntaxOperator": { "dark": "darkWarm", "light": "lightWarm" },
    "syntaxPunctuation": { "dark": "darkMuted", "light": "lightMuted" }
  }
}
