{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "model": "azure/gpt-5-6-sol",
  "small_model": "azure/gpt-5-6-luna",
  "provider": {
    "litelm": {
      "npm": "@ai-sdk/openai",
      "name": "sbp",
      "options": {
        "baseURL": "https://litellm.sbp.ai/v1",
        "apiKey": "{env:SBP_AI_API_KEY}"
      },
      "models": {
        "azure/gpt-5-6-sol": {
          "name": "azure/gpt-5-6-sol",
          "limit": {
            "context": 1050000,
            "output": 128000
          }
        },
        "azure/gpt-5-6-terra": {
          "name": "azure/gpt-5-6-terra",
          "limit": {
            "context": 1050000,
            "output": 128000
          }
        },
        "azure/gpt-5-6-luna": {
          "name": "azure/gpt-5-6-luna",
          "limit": {
            "context": 1050000,
            "output": 128000
          }
        }
      }
    }
  }
}
