{
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "DISABLE_BUG_COMMAND": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {},
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git remote -v)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git rm*)",
      "Bash(git pull --rebase*)",
      "Bash(git push*)",
      "Bash(gh run view*)",
      "Bash(gh run list*)",
      "Bash(gh run watch*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr checks*)",
      "Bash(gh repo view*)",
      "Bash(ls*)",
      "Bash(wc*)",
      "Bash(which*)",
      "Bash(head*)",
      "Bash(find*)",
      "Bash(mise --version)",
      "Bash(mise doctor*)",
      "Bash(uv run ruff check*)",
      "Bash(uv run ruff format --check*)",
      "Bash(uv run basedpyright*)",
      "Bash(uv run pytest*)",
      "Bash(pnpm lint*)",
      "Bash(pnpm typecheck*)",
      "Bash(pnpm build*)",
      "Bash(pnpm test*)",
      "Bash(go test*)",
      "Bash(go vet*)",
      "Bash(go build*)",
      "Bash(go version)",
      "Bash(go env*)",
      "Bash(cargo check*)",
      "Bash(cargo test*)",
      "Bash(cargo --version)",
      "Bash(python3 -m py_compile*)",
      "Bash(python3 --version)",
      "Bash(node --version)",
      "Bash(rustc --version)",
      "Bash(gh --version)"
    ],
    "deny": [
      "Bash(git commit --amend*)",
      "Bash(git commit --no-verify*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push --delete*)",
      "Bash(git push -d*)",
      "Bash(git push --prune*)",
      "Bash(git push * --force*)",
      "Bash(git push * -f*)",
      "Bash(git push * --delete*)",
      "Bash(git push * -d*)",
      "Bash(git push * --prune*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf $HOME*)",
      "Bash(find * -delete*)",
      "Bash(find * -exec *)",
      "Bash(find * -execdir *)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  }
}
