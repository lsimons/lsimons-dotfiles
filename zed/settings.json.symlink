// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "icon_theme": "Colored Zed Icons Theme Light",
  "language_models": {
    "openai_compatible": {
      "sbp": {
        "api_url": "https://litellm.sbp.ai/v1",
        "available_models": [
          {
            "name": "aws/claude-4-6-sonnet",
            "max_tokens": 200000,
            "max_output_tokens": 64000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true
            }
          }
        ]
      }
    }
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    },
    "gemini": {
      "type": "registry"
    },
    "github-copilot-cli": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "right"
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "agent": {
    "dock": "left",
    "tool_permissions": {
      "tools": {
        "create_directory": {
          "always_allow": [
            {
              "pattern": "^lsimons\\-dotfiles/"
            }
          ]
        }
      }
    },
    "default_profile": "write",
    "default_model": {
      "effort": "high",
      "enable_thinking": false,
      "provider": "copilot_chat",
      "model": "gpt-5-mini"
    },
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "claude-haiku-4.5",
        "enable_thinking": false
      },
      {
        "provider": "copilot_chat",
        "model": "claude-sonnet-4.6",
        "enable_thinking": false
      },
      {
        "provider": "copilot_chat",
        "model": "gpt-5.4",
        "enable_thinking": false
      },
      {
        "provider": "sbp",
        "model": "aws/claude-4-6-sonnet",
        "enable_thinking": false
      },
      {
        "provider": "copilot_chat",
        "model": "claude-opus-4.6",
        "enable_thinking": true,
        "effort": "high"
      },
      {
        "provider": "copilot_chat",
        "model": "gpt-5-mini",
        "enable_thinking": false,
        "effort": "high"
      }
    ],
    "model_parameters": []
  },
  "edit_predictions": {
    "provider": "copilot"
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "terminal": {
    "env": {
      "PATH": "${HOME}/.local/share/mise/shims:${HOME}/.local/bin:${PATH}"
    }
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "light",
    "light": "Claude Warm Light",
    "dark": "Claude Warm"
  }
}
